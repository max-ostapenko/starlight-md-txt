{
  "name": "starlight-md-txt",
  "version": "0.0.1",
  "description": "Starlight plugin to expose documentation pages as raw, agent-friendly Markdown at .md.txt URLs",
  "type": "module",
  "workspaces": [
    "docs"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "build:docs": "npm run build && npm run build --workspace=docs"
  },
  "keywords": [
    "astro",
    "starlight",
    "plugin",
    "markdown",
    "agent",
    "llm"
  ],
  "author": "Max Ostapenko",
  "license": "MIT",
  "peerDependencies": {
    "@astrojs/starlight": ">=0.30.0",
    "astro": ">=4.0.0 || >=5.0.0"
  },
  "dependencies": {
    "remark-mdx": "^3.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.40.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "astro": "^6.4.8",
    "typescript": "^5.0.0"
  }
}
